apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: <certificate-authority-data>
    server: https://<server>:6443
  name: truejit-cluster
contexts:
- context:
    cluster: truejit-cluster
    user: khordadi
  name: khordadi@truejit-cluster
current-context: khordadi@truejit-cluster
kind: Config
preferences: {}
users:
- name: khordadi
  user:
    client-certificate-data: <client-certificate-data>
    client-key-data: <client-key-data>
