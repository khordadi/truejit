johnripper.c -fgcse -fgcse-las -fgcse-lm -fgcse-sm -o johnripper_fgcse_fgcse_las_fgcse_lm_fgcse_sm.s
johnripper.c -fexpensive-optimizations -o johnripper_fexpensive_optimizations.s
