johnripper.c -O5 -fpic -fipa-pta -fselective-scheduling -fselective-scheduling2 -o johnripper_O5_fpic_fpic_pta_fselective_scheduling_fselective_scheduling2.s
johnripper.c -falign-functions -falign-jumps -falign-labels -falign-loops -o johnripper_falign_functions_falign_jumps_falign_labels_falign_loops.s
johnripper.c -fbranch-probabilities -fbranch-target-load-optimize -fbranch-target-load-optimize2 -o johnripper_fbranch_probabilities_fbranch_target_load_optimize_fbranch_target_load_optimize2.s
